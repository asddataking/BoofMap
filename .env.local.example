# Copy to .env.local for local development (never commit .env.local).
# Production template: see .env.example

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Written by `npx convex dev` if missing:
NEXT_PUBLIC_CONVEX_URL=

# Clerk test keys (Dashboard → API Keys → Development)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Frontend API URL — same value in Convex dev deployment env
CLERK_FRONTEND_API_URL=https://your-app.clerk.accounts.dev

# Admin (Clerk user ID from /profile after first sign-in)
ADMIN_USER_IDS=
ADMIN_EMAILS=

# Optional: show /admin nav before Convex profile loads
NEXT_PUBLIC_ADMIN_USER_IDS=
NEXT_PUBLIC_ADMIN_EMAILS=

# Optional: admin AI chat in /admin
OPENAI_API_KEY=
