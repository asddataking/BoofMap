# Public site URL — use www in production (matches Vercel primary domain)
NEXT_PUBLIC_SITE_URL=https://www.boofmap.com

# Convex production deployment URL (from convex deploy / dashboard)
NEXT_PUBLIC_CONVEX_URL=

# Clerk production keys (Dashboard → API Keys → Production)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Clerk Frontend API URL — JWT issuer for Convex (production instance)
# Example: https://clerk.boofmap.com or https://your-app.clerk.accounts.dev
# Set the same value in Convex Dashboard → Production → Environment Variables
CLERK_FRONTEND_API_URL=

# Comma-separated Clerk user IDs for /admin access (Convex + optional local reference)
ADMIN_USER_IDS=

# Comma-separated admin emails (works alongside ADMIN_USER_IDS)
ADMIN_EMAILS=

# Client-side admin nav hint (same IDs/emails as above)
NEXT_PUBLIC_ADMIN_USER_IDS=
NEXT_PUBLIC_ADMIN_EMAIL=

# OpenAI API key for the admin AI assistant chat
OPENAI_API_KEY=

# Cloudflare R2 — set in Convex Dashboard → Production → Environment Variables
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
