# BoofMap — production environment template (Vercel Production + Convex Production)
# Copy to .env.local only for local testing with production keys (not recommended).
# Local dev: use .env.local.example instead.

# --- Vercel (Next.js) ---

# Canonical public URL (use www in production)
NEXT_PUBLIC_SITE_URL=https://www.boofmap.com

# Convex production deployment URL (from `npx convex deploy`)
NEXT_PUBLIC_CONVEX_URL=

# Clerk production keys (Dashboard → API Keys → Production)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Clerk JWT issuer for Convex auth — set on Vercel AND Convex production env
# Example: https://clerk.boofmap.com or https://your-app.clerk.accounts.dev
CLERK_FRONTEND_API_URL=

# Alternate issuer name (optional; CLERK_FRONTEND_API_URL takes precedence)
# CLERK_JWT_ISSUER_DOMAIN=

# Admin access for /admin (server-enforced on Convex + Next API routes)
ADMIN_USER_IDS=
ADMIN_EMAILS=

# Optional: client-side /admin nav hint (same values as above)
NEXT_PUBLIC_ADMIN_USER_IDS=
NEXT_PUBLIC_ADMIN_EMAILS=

# Admin AI assistant (/api/admin/chat)
OPENAI_API_KEY=

# --- Convex Dashboard → Production → Environment Variables ---
# (Not set on Vercel — R2 uploads run in Convex actions)

# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
#
# Also mirror on Convex production:
# ADMIN_USER_IDS, ADMIN_EMAILS, CLERK_FRONTEND_API_URL
