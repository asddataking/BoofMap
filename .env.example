# Public site URL for SEO, sitemap, and Open Graph (production)
# Example: https://boofmap.com
NEXT_PUBLIC_SITE_URL=

# Convex (https://docs.convex.dev)
NEXT_PUBLIC_CONVEX_URL=

# Clerk (https://clerk.com) — Next.js app keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk Frontend API URL (JWT issuer for Convex) — from Clerk Dashboard
# Example: https://flying-gazelle-10.clerk.accounts.dev
# Also set CLERK_FRONTEND_API_URL in Convex Dashboard → Settings → Environment Variables
CLERK_FRONTEND_API_URL=

# Comma-separated Clerk user IDs for /admin access (Convex + optional local reference)
ADMIN_USER_IDS=

# Comma-separated admin emails (works alongside ADMIN_USER_IDS)
ADMIN_EMAILS=

# Client-side admin nav hint (same IDs/emails as above)
NEXT_PUBLIC_ADMIN_USER_IDS=
NEXT_PUBLIC_ADMIN_EMAIL=

# OpenAI API key for the admin AI assistant chat
OPENAI_API_KEY=

# Cloudflare R2 — set in Convex Dashboard → Settings → Environment Variables
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
